{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "outDir": "dist",
    "types": [
      "node",
      "vitest/globals"
    ],
    "jsx": "react-jsx"
  },
  "include": [
    "src",
    "test",
    "tests",
    "tsup.config.ts",
    "vitest.config.ts"
  ]
}
